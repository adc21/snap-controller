[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
PySide6 = ">=6.5.0"
matplotlib = ">=3.7.0"
numpy = ">=1.24.0"
pandas = ">=2.0.0"
Pillow = ">=9.0.0"
pyqtdarktheme = ">=2.1.0"
qtawesome = ">=1.2.0"
openpyxl = ">=3.1.0"
scipy = ">=1.10.0"
# NAP→s8i 変換 (SNAP.exe GUI 自動操作) 用 — Windows 限定
pywinauto = {version = ">=0.6.8", markers = "sys_platform == 'win32'"}
